# Port the application listens on
PORT=3000

# Secret key for signing JWT cookies (generate a long random value)
JWT_SECRET=super-secret-key-change-this-in-production-1234567890

# Token expiration time
JWT_EXPIRES_IN=7d

# Default password for seeded users
SEED_DEFAULT_PASSWORD=adgrades123

# Node Environment (production / development)
NODE_ENV=development

# Database Configuration
DB_PATH=./data/app.db

# Backup Directory
BACKUP_DIR=./backups

# Set to true only if accessing over HTTPS
COOKIE_SECURE=false

# App Timezone
TZ=Asia/Kolkata

# Telegram Bot configurations (optional, keep blank to disable)
TELEGRAM_BOT_TOKEN=
REMINDER_CRON=0 9 * * *
BREAK_REMINDER_CRON=*/90 * * * *
WORK_HOURS_START=10
WORK_HOURS_END=19
